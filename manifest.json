{
  "manifest_version": 3,
  "version": "1.0.0",
  "short_name": "AA",
  "name": "AuthenticatorAnywhere",
  "description": "A Web Authenicator App that you can use on any modern browser (Chrome, Edge, Safari) and on any desktop or mobile device",
  "icons": [
    {
      "src": "./512.svg",
      "type": "image/svg+xml",
      "sizes": "512x512"
    },
    {
      "src": "./192.svg",
      "type": "image/svg+xml",
      "sizes": "192x192"
    }
  ],
  "id": "/JsTOTPAuthenticator/",
  "start_url": "https://vpelss.github.io/AuthenticatorAnywhere/",
  "background_color": "#3367D6",
